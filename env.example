# ─────────────────────────────────────────
#  CrimeLens — SQL Server connection settings
#  Copy this file as .env and fill in your values
# ─────────────────────────────────────────

# SQL Server host — use 'localhost' or your machine's IP / server name
DB_SERVER=localhost\SQLEXPRESS

# Database name (as it appears in SQL Server Management Studio)
DB_NAME=CrimeDB

# SQL Server login username
DB_USER=sa

# SQL Server login password
DB_PASSWORD=your_password_here

# Flask settings
FLASK_ENV=development
FLASK_PORT=5000
